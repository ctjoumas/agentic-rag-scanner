{
  "version": "0.2.0",
  "configurations": [
    {
      "name": ".NET Launch API (HTTP+HTTPS)",
      "type": "coreclr",
      "request": "launch",
      "preLaunchTask": "build",
      "program": "${workspaceFolder}/AgenticRagScannerApi/bin/Debug/net10.0/AgenticRagScannerApi.dll",
      "args": [],
      "cwd": "${workspaceFolder}/AgenticRagScannerApi",
      "stopAtEntry": false,
      "env": {
        "ASPNETCORE_ENVIRONMENT": "Development",
        "ASPNETCORE_URLS": "https://localhost:7180;http://localhost:5180"
      },
      "console": "integratedTerminal",
      "serverReadyAction": {
        "action": "openExternally",
        "pattern": "\\bNow listening on:\\s+(https?://\\S+)",
        "uriFormat": "%s/scalar/v1"
      }
    },
    {
      "name": ".NET Launch API (HTTPS)",
      "type": "coreclr",
      "request": "launch",
      "preLaunchTask": "build",
      "program": "${workspaceFolder}/AgenticRagScannerApi/bin/Debug/net10.0/AgenticRagScannerApi.dll",
      "args": [],
      "cwd": "${workspaceFolder}/AgenticRagScannerApi",
      "stopAtEntry": false,
      "env": {
        "ASPNETCORE_ENVIRONMENT": "Development",
        "ASPNETCORE_URLS": "https://localhost:7180;http://localhost:5180"
      },
      "console": "integratedTerminal",
      "serverReadyAction": {
        "action": "openExternally",
        "pattern": "\\bNow listening on:\\s+(https?://\\S+)",
        "uriFormat": "%s/scalar/v1"
      }
    },
    {
      "name": ".NET Attach to Running API",
      "type": "coreclr",
      "request": "attach",
      "processId": "${command:pickProcess}"
    }
  ],
  "compounds": [
    {
      "name": "Start API and Attach",
      "configurations": [
        ".NET Launch API (HTTP+HTTPS)",
        ".NET Attach to Running API"
      ],
      "stopAll": true
    }
  ]
}
