{
  "//": "Copy this file to 'appsettings.Local.json' and fill in real values for local dev.",
  "//secrets": "appsettings.Local.json is git-ignored. NEVER commit real endpoints, keys, or connection strings (public repo — see architecture-context.md §1).",
  "//auth": "Prefer DefaultAzureCredential where possible; the ApiKey/ConnectionString fields exist for local development only.",
  "ApplicationInsights": {
    "ConnectionString": ""
  },
  "AzureStorage": {
    "BlobServiceUri": "https://<your-account>.blob.core.windows.net",
    "ConnectionString": "",
    "DocumentsContainer": "documents",
    "ExportsContainer": "exports"
  },
  "AzureSearch": {
    "Endpoint": "https://<your-service>.search.windows.net",
    "IndexName": "<your-index-name>",
    "ApiKey": ""
  },
  "Foundry": {
    "Endpoint": "https://<your-foundry-endpoint>",
    "ModelDeploymentName": "<your-model-deployment-name>",
    "ApiKey": ""
  },
  "Cosmos": {
    "Endpoint": "https://cosmoswxdev001.documents.azure.com:443/",
    "Database": "agentic-rag-scanner",
    "CheckpointsContainer": "checkpoints"
  },
  "WebSearch": {
    "ProjectEndpoint": "https://<your-foundry-resource>.services.ai.azure.com/api/projects/<your-project>",
    "AgentName": "<your-web-search-agent-name>",
    "MaxResults": 10
  }
}
