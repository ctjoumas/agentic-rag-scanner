{
  "Serilog": {
    "Using": [ "Serilog.Sinks.Console" ],
    "MinimumLevel": {
      "Default": "Information",
      "Override": {
        "Microsoft": "Warning",
        "Microsoft.AspNetCore": "Warning",
        "Microsoft.Hosting.Lifetime": "Information"
      }
    },
    "Enrich": [ "FromLogContext" ],
    "WriteTo": [
      {
        "Name": "Console"
      }
    ]
  },
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  "ApplicationInsights": {
    "ConnectionString": ""
  },
  "AllowedHosts": "*",
  "AzureStorage": {
    "BlobServiceUri": "<your-blob-service-uri>",
    "DocumentsContainer": "documents",
    "ExportsContainer": "exports"
  },
  "AzureSearch": {
    "Endpoint": "<your-search-endpoint>",
    "IndexName": "<your-index-name>",
    "ApiKey": ""
  },
  "Foundry": {
    "Endpoint": "<your-foundry-endpoint>",
    "ModelDeploymentName": "<your-model-deployment-name>",
    "ApiKey": ""
  },
  "Cosmos": {
    "Endpoint": "<your-cosmos-endpoint>",
    "Database": "agentic-rag-scanner",
    "CheckpointsContainer": "checkpoints"
  },
  "WebSearch": {
    "ProjectEndpoint": "<your-foundry-project-endpoint>",
    "AgentName": "<your-web-search-agent-name>",
    "MaxResults": 10,
    "RequestTimeoutSeconds": 300
  },
  "Fetch": {
    "AllowedContentTypes": [ "text/html", "application/xhtml+xml", "application/pdf" ],
    "MaxResponseMegabytes": 10,
    "MaxRedirects": 5,
    "RequestTimeoutSeconds": 30
  }
}
