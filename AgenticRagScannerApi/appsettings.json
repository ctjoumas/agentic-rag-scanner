{
  "Serilog": {
    "Using": [ "Serilog.Sinks.Console" ],
    "MinimumLevel": {
      "Default": "Information",
      "Override": {
        "Microsoft": "Warning",
        "Microsoft.AspNetCore": "Warning",
        "Microsoft.Hosting.Lifetime": "Information"
      }
    },
    "Enrich": [ "FromLogContext" ],
    "WriteTo": [
      {
        "Name": "Console"
      }
    ]
  },
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  "ApplicationInsights": {
    "ConnectionString": ""
  },
  "AllowedHosts": "*",
  "AzureStorage": {
    "BlobServiceUri": "<your-blob-service-uri>",
    "ConnectionString": "",
    "DocumentsContainer": "documents",
    "ExportsContainer": "exports"
  },
  "AzureSearch": {
    "Endpoint": "<your-search-endpoint>",
    "IndexName": "<your-index-name>",
    "ApiKey": ""
  },
  "Foundry": {
    "Endpoint": "<your-foundry-endpoint>",
    "ModelDeploymentName": "<your-model-deployment-name>",
    "ApiKey": ""
  },
  "Cosmos": {
    "Endpoint": "<your-cosmos-endpoint>",
    "Database": "agentic-rag-scanner",
    "CheckpointsContainer": "checkpoints"
  },
  "WebSearch": {
    "ProjectEndpoint": "<your-foundry-project-endpoint>",
    "ModelDeploymentName": "<your-model-deployment-name>",
    "AgentName": "WebSearch",
    "ConnectionId": "<your-bing-custom-search-connection-id>",
    "InstanceName": "<your-bing-custom-search-instance-name>",
    "MaxResults": 10
  }
}
